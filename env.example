# Supabase（Project Settings → API）
# このファイルをコピーして .env.local を作成し、値を埋めてください。

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Project Settings → API → service_role（サーバー専用・Git に含めない）
# 共有リンク /api/guest でタスクを読み書きするために必須
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Auth: Authentication → URL Configuration に次を追加
#   Site URL: http://localhost:3000 （本番では実 URL）
#   Redirect URLs: http://localhost:3000/auth/callback
